---
import DocMenu from '@cypress-design/vue-docmenu'
import { getAllComponents } from '../lib/components'

interface Props {
  currentPath: string
}

const { currentPath } = Astro.props

const componentNames = getAllComponents().map((c) => c.name)

const docPageGlob = import.meta.glob<{ frontmatter?: { title?: string; order?: number } }>(
  '../pages/*.mdx',
  { eager: true },
)
const docPages = Object.entries(docPageGlob)
  .map(([path, mod]) => ({
    href: path.replace('../pages', '').replace('.mdx', '').replace('/index', '/') || '/',
    label: mod.frontmatter?.title ?? path.split('/').pop()?.replace('.mdx', '') ?? '',
    order: mod.frontmatter?.order ?? 99,
  }))
  .sort((a, b) => a.order - b.order || a.label.localeCompare(b.label))

const patternGlob = import.meta.glob<{ frontmatter?: { title?: string; order?: number } }>(
  '../pages/patterns/*.mdx',
  { eager: true },
)
const patternPages = Object.entries(patternGlob)
  .map(([path, mod]) => ({
    href: path.replace('../pages', '').replace('.mdx', ''),
    label: mod.frontmatter?.title ?? path.split('/').pop()?.replace('.mdx', '') ?? '',
    order: mod.frontmatter?.order ?? 99,
  }))
  .sort((a, b) => a.order - b.order || a.label.localeCompare(b.label))

const items = [
  ...docPages.map((p) => ({ label: p.label, href: p.href })),
  {
    label: 'Components',
    items: componentNames.map((name) => ({ label: name, href: `/components/${name}` })),
  },
  ...(patternPages.length > 0
    ? [{ label: 'Patterns', items: patternPages.map((p) => ({ label: p.label, href: p.href })) }]
    : []),
]
---

<div class="pl-4 md:py-4 w-[250px]">
  <DocMenu
    client:only="vue"
    items={items}
    activePath={currentPath}
  />
</div>
