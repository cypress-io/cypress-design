---
/**
 * [component].astro — canonical template for all component documentation pages.
 *
 * URL: /components/Button, /components/Tabs, etc.
 *
 * Structure rendered per page:
 *   1. <FrameworkTabs> — tab buttons for each supported framework
 *   2. Common intro (ReadMe.md at component root) — framework-agnostic desc + Figma link
 *   3. Per-framework sections inside <F only="<fw>"> wrappers
 *      (Install + Usage + code examples — live fences stripped to static by remark plugin)
 *   4. instructions.md — hand-written props/events/slots reference (if present)
 */
import BaseLayout from '../../layouts/BaseLayout.astro'
import F from '../../components/F.astro'
import FrameworkTabs from '../../components/FrameworkTabs.astro'
import { getAllComponents } from '../../lib/components'

// Per-component live demos — see docs/src/demos/ for one .astro file per component.
// Each demo imports the actual Vue/React component and renders it with `client:only`.
// Components without a demo file render without one (no error).
const demoModules = import.meta.glob<{ default: any }>('../../demos/*.astro', { eager: true })

// ---------------------------------------------------------------------------
// Static paths — one route per component directory
// ---------------------------------------------------------------------------
export function getStaticPaths() {
  return getAllComponents().map(({ name, frameworks, hasInstructions }) => {
    return {
      params: { component: name },
      props: { frameworks, hasInstructions },
    }
  })
}

interface Props {
  frameworks: string[]
  hasInstructions: boolean
}

const { component } = Astro.params
const { frameworks, hasInstructions } = Astro.props

// ---------------------------------------------------------------------------
// Dynamic content imports
// Globs must be string literals; we index into them with the dynamic key.
// Paths are relative to this file → ../../../../ = repo root.
// ---------------------------------------------------------------------------
// Per-framework ReadMes only. The framework-agnostic ReadMe.md at the
// component root contains VitePress-specific <script setup> + <DemoWrapper>
// markup that doesn't render correctly in Astro/MDX, so it's intentionally
// skipped — the per-framework ReadMes already cover install + usage.
const vueReadmes    = import.meta.glob('../../../../components/*/vue/ReadMe.md')
const reactReadmes  = import.meta.glob('../../../../components/*/react/ReadMe.md')
const vanillaReadmes = import.meta.glob('../../../../components/*/vanilla/ReadMe.md')
const astroReadmes  = import.meta.glob('../../../../components/*/astro/ReadMe.md')
const instructionsMds = import.meta.glob('../../../../components/*/instructions.md')

async function loadContent(glob: Record<string, () => Promise<unknown>>, key: string) {
  const loader = glob[key]
  if (!loader) return null
  const mod = await loader() as { Content?: unknown }
  return (mod.Content ?? null) as import('astro').AstroInstance['default'] | null
}

const base = `../../../../components/${component}`
const VueContent         = await loadContent(vueReadmes,      `${base}/vue/ReadMe.md`)
const ReactContent       = await loadContent(reactReadmes,    `${base}/react/ReadMe.md`)
const VanillaContent     = await loadContent(vanillaReadmes,  `${base}/vanilla/ReadMe.md`)
const AstroContent       = await loadContent(astroReadmes,    `${base}/astro/ReadMe.md`)
const InstructionsContent = hasInstructions
  ? await loadContent(instructionsMds, `${base}/instructions.md`)
  : null

const Demo = demoModules[`../../demos/${component}.astro`]?.default ?? null
---

<BaseLayout title={component}>
  <h1 class="markdown-title">{component}</h1>

  {Demo && <Demo />}

  <FrameworkTabs frameworks={frameworks} />

  {/* Per-framework sections */}
  {frameworks.includes('vue') && VueContent && (
    <F only="vue">
      <div class="component-framework markdown">
        <VueContent />
      </div>
    </F>
  )}

  {frameworks.includes('react') && ReactContent && (
    <F only="react">
      <div class="component-framework markdown">
        <ReactContent />
      </div>
    </F>
  )}

  {frameworks.includes('vanilla') && VanillaContent && (
    <F only="vanilla">
      <div class="component-framework markdown">
        <VanillaContent />
      </div>
    </F>
  )}

  {frameworks.includes('astro') && AstroContent && (
    <F only="astro">
      <div class="component-framework markdown">
        <AstroContent />
      </div>
    </F>
  )}

  {/* Props / events / slots reference */}
  {InstructionsContent && (
    <div class="component-instructions markdown mt-8 pt-8 border-t border-gray-100">
      <InstructionsContent />
    </div>
  )}
</BaseLayout>
