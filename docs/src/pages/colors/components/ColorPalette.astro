---
type ColorStep = {
  step: string
  hex: string
  tailwindClass: string
  textColor: string
  wcagGrade: string
  wcagPasses: boolean
  isDark: boolean
}

type ColorScale = {
  tier: string
  name: string
  role: string
  desc: string
  processedSteps: ColorStep[]
  midHex: string
  cols: number
}

function hexToRgb(h: string): [number, number, number] {
  const hex = h.replace('#', '')
  return [parseInt(hex.slice(0, 2), 16), parseInt(hex.slice(2, 4), 16), parseInt(hex.slice(4, 6), 16)]
}

function lum([r, g, b]: [number, number, number]): number {
  const ch = [r, g, b].map((v) => {
    v /= 255
    return v <= 0.03928 ? v / 12.92 : Math.pow((v + 0.055) / 1.055, 2.4)
  })
  return 0.2126 * ch[0] + 0.7152 * ch[1] + 0.0722 * ch[2]
}

function contrastRatio(a: string, b: string): number {
  const la = lum(hexToRgb(a))
  const lb = lum(hexToRgb(b))
  const [L, D] = la > lb ? [la, lb] : [lb, la]
  return (L + 0.05) / (D + 0.05)
}

function wcagGrade(r: number): string {
  if (r >= 7) return 'AAA'
  if (r >= 4.5) return 'AA'
  return '·'
}

const INK = '#1B1E2E'
const WHITE = '#ffffff'

function contrastTextOn(hex: string): string {
  return contrastRatio(hex, WHITE) >= contrastRatio(hex, INK) ? WHITE : INK
}

const PALETTE_DATA = [
  { tier: 'Primary', name: 'gray', role: 'ink · neutrals', desc: 'The foundation: text, borders, dividers, surfaces. Every other scale leans on these steps to set hierarchy.', steps: { 25: '#FAFAFC', 50: '#F3F4FA', 100: '#E1E3ED', 200: '#D0D2E0', 300: '#BFC2D4', 400: '#AFB3C7', 500: '#9095AD', 600: '#747994', 700: '#5A5F7A', 800: '#434861', 900: '#2E3247', 950: '#25283C', 1000: '#1B1E2E', 1100: '#161827' } },
  { tier: 'Primary', name: 'jade', role: 'success · passing', desc: 'Cypress green. Reserve for healthy system state — passing tests, positive deltas, successful deploys. Never generic confirmation.', steps: { 50: '#E4FBF2', 100: '#C2F1DE', 200: '#A3E7CB', 300: '#69D3A7', 400: '#1FA971', 500: '#00814D', 600: '#005F39', 700: '#00442A', 800: '#003220', 900: '#00291B', 1000: '#00261A' } },
  { tier: 'Primary', name: 'teal', role: 'brand · primary', desc: 'Cypress teal. Brand surfaces, primary marketing, and the hue users associate first with the product.', steps: { 50: '#E0F6FA', 100: '#B7E7F0', 200: '#90D9E6', 300: '#4BBFD2', 400: '#0097A8', 500: '#007780', 600: '#00595D', 700: '#004143', 800: '#003131', 900: '#002828', 1000: '#002525' } },
  { tier: 'Primary', name: 'indigo', role: 'accent · links', desc: 'Links, focus rings, and the places attention should land first. The accent that signals interactivity.', steps: { 50: '#F0F1FF', 100: '#DADDFE', 200: '#C5C9FD', 300: '#9AA2FC', 400: '#6470F3', 500: '#4956E3', 600: '#3A46CC', 700: '#2F3AB0', 800: '#252E8F', 900: '#1C236D', 1000: '#151A50' } },
  { tier: 'Secondary', name: 'purple', role: 'accent', desc: 'Used for accents, occasional highlights, and complement to teal. Pairs cleanly with the primary scales without competing.', steps: { 50: '#F5F0FB', 100: '#E9DDFA', 200: '#DECBF8', 300: '#C8A7F5', 400: '#A06CE4', 500: '#7F43C9', 600: '#632AA6', 700: '#4B1A83', 800: '#3B1268', 900: '#320E58', 1000: '#2F0C52' } },
  { tier: 'Secondary', name: 'red', role: 'error · failing', desc: 'Destructive actions, failed tests, errors, blockers. Used sparingly so it keeps its weight where it matters.', steps: { 50: '#FBEFF1', 100: '#FAD9DF', 200: '#F8C4CD', 300: '#F59AA9', 400: '#E45770', 500: '#C62B49', 600: '#9F1331', 700: '#7A0723', 800: '#5E021B', 900: '#4F0018', 1000: '#490018' } },
  { tier: 'Secondary', name: 'orange', role: 'warning', desc: 'Flaky tests, pending states, rate limits, degraded behavior. Warmer than red — attention without alarm.', steps: { 50: '#F5F4D7', 100: '#F3ECB3', 200: '#F1E08F', 300: '#EDBB4A', 400: '#DB7903', 500: '#BD5800', 600: '#963F00', 700: '#702C00', 800: '#521F00', 900: '#411800', 1000: '#391500' } },
  { tier: 'Tertiary', name: 'fuchsia', role: 'generated content', desc: 'Reserved for generated content — syntax highlighting, chart series, data visualizations with many points.', steps: { 50: '#FAEFFB', 100: '#F7DAF9', 200: '#F3C6F8', 300: '#ED9FF4', 400: '#D65FE3', 500: '#B735C7', 600: '#901CA2', 700: '#6C0F7E', 800: '#510862', 900: '#400651', 1000: '#39054A' } },
  { tier: 'Tertiary', name: 'green', role: 'generated content', desc: 'Reserved for generated content. A yellow-green for chart series and code highlights — distinct from jade.', steps: { 50: '#F5F5D0', 100: '#E7E8AB', 200: '#DADC89', 300: '#BDC44D', 400: '#849706', 500: '#5B7100', 600: '#405500', 700: '#2E4000', 800: '#233200', 900: '#1C2A00', 1000: '#192500' } },
  { tier: 'Tertiary', name: 'magenta', role: 'generated content', desc: 'Reserved for generated content — additional chart series and syntax highlighting tones.', steps: { 50: '#FCEEF5', 100: '#FADAEA', 200: '#F9C5DF', 300: '#F69ECA', 400: '#E45DA3', 500: '#C53282', 600: '#9C1964', 700: '#750C4D', 800: '#59063D', 900: '#490435', 1000: '#420333' } },
]

const TIERS = ['Primary', 'Secondary', 'Tertiary']

const TIER_BLURBS: Record<string, string> = {
  Primary: 'Used frequently as the base colors for establishing the brand. Common across products, docs, and marketing.',
  Secondary: 'Generally used as accent colors and for semantic purposes throughout products, docs, and marketing.',
  Tertiary: 'Reserved for generated content — syntax highlighting, charts with many data points. Use only when necessary.',
}

const PALETTE: ColorScale[] = PALETTE_DATA.map((scale) => {
  const stepEntries = Object.entries(scale.steps)
  const cols = Math.ceil(stepEntries.length / 2)
  const midHex = (scale.steps as Record<string | number, string>)[500]

  const processedSteps: ColorStep[] = stepEntries.map(([step, hex]) => {
    const textColor = contrastTextOn(hex)
    const isDark = textColor === WHITE
    const r = contrastRatio(hex, isDark ? WHITE : INK)
    return {
      step,
      hex,
      tailwindClass: `bg-${scale.name}-${step}`,
      textColor,
      isDark,
      wcagGrade: wcagGrade(r),
      wcagPasses: r >= 4.5,
    }
  })

  return { ...scale, processedSteps, midHex, cols }
})
---

{TIERS.map((tier) => {
  const scales = PALETTE.filter((s) => s.tier === tier)
  return (
    <div>
      <div class="mt-[72px] pb-8 border-b border-gray-100 first:mt-2">
        <h3 class="font-['Poppins'] font-semibold text-[28px] mb-2 text-gray-1000 mt-0">{tier} colors</h3>
        <p class="text-base font-normal text-gray-700 m-0 leading-[1.4]">{TIER_BLURBS[tier]}</p>
      </div>

      {scales.map((scale, i) => (
        <section
          class={`mb-10 ${i > 0 ? 'pt-6 border-t border-gray-100' : ''}`}
        >
          <div class="flex flex-col gap-2 mb-4 max-w-[680px]">
            <h3 id={`scale-${scale.name}`} class="font-['Poppins'] font-semibold text-2xl m-0 flex items-center gap-3 text-gray-1000">
              <span
                class="w-4 h-4 rounded border border-black/[.08] inline-block shrink-0"
                style={`background:${scale.midHex}`}
              ></span>
              {scale.name.charAt(0).toUpperCase() + scale.name.slice(1)}
            </h3>
            <p class="text-base font-normal text-gray-700 leading-[1.4] m-0">{scale.desc}</p>
          </div>

          <div
            class="grid gap-2"
            style={`grid-template-columns: repeat(${scale.cols}, minmax(0, 1fr))`}
          >
            {scale.processedSteps.map(({ step, hex, tailwindClass, textColor, isDark, wcagGrade, wcagPasses }) => (
              <button
                class="swatch group relative flex flex-col justify-between h-[88px] rounded p-2 cursor-pointer border border-black/[.06] transition-[transform,box-shadow] duration-[120ms] ease-out hover:-translate-y-0.5 hover:shadow-[0_6px_14px_-6px_rgba(27,30,46,.22)] active:translate-y-0 text-left"
                style={`background:${hex};color:${textColor}`}
                data-copy={tailwindClass}
                title={`Copy ${tailwindClass}`}
              >
                <div class="font-mono text-[12px] font-semibold opacity-90">{step}</div>
                <div class="flex items-end justify-between gap-[3px]">
                  <span class="font-mono text-[9.5px] font-medium opacity-80">
                    {hex.replace('#', '').toUpperCase()}
                  </span>
                  <span
                    class={`font-mono text-[8px] font-bold px-1 py-[1px] rounded-[3px] leading-[1.3] shrink-0 ${isDark ? 'bg-white/25' : 'bg-black/[.09]'} ${wcagPasses ? '' : 'opacity-45'}`}
                  >
                    {wcagGrade}
                  </span>
                </div>
                <div
                  class="sw-copied absolute inset-0 grid place-items-center font-mono text-[12px] font-semibold opacity-0 transition-opacity duration-[180ms] pointer-events-none rounded"
                  style={`background:${hex};color:${textColor}`}
                >
                  Copied
                </div>
              </button>
            ))}
          </div>
        </section>
      ))}
    </div>
  )
})}

<style>
  .swatch.copied .sw-copied {
    opacity: 1;
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('.swatch[data-copy]').forEach((btn) => {
    btn.addEventListener('click', () => {
      navigator.clipboard?.writeText(btn.dataset.copy ?? '')
      btn.classList.add('copied')
      setTimeout(() => btn.classList.remove('copied'), 900)
    })
  })
</script>
