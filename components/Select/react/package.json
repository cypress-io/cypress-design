{
  "name": "@cypress-design/react-select",
  "version": "0.0.0",
  "files": [
    "*"
  ],
  "typings": "./dist/index.d.ts",
  "main": "./dist/index.umd.js",
  "module": "./dist/index.es.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.es.mjs",
      "require": "./dist/index.umd.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "yarn build:module && yarn build:types",
    "build:module": "rollup -c ./rollup.config.mjs",
    "build:types": "tsc --project ./tsconfig.types.json && rollup -c ./rollup.dts.config.mjs && rimraf dist/dts"
  },
  "dependencies": {
    "@cypress-design/react-button": "*",
    "@cypress-design/react-checkbox": "*",
    "@cypress-design/react-icon": "*",
    "@cypress-design/react-tabs": "*",
    "@cypress-design/react-tag": "*",
    "@cypress-design/react-textbox": "*",
    "clsx": "*"
  },
  "devDependencies": {
    "@cypress-design/constants-select": "*",
    "@cypress-design/rollup-plugin-tailwind-keep": "*"
  },
  "license": "MIT"
}
